<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<div class="container-fluid py-4">

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h3 class="mb-1">Approved PSU Profile </h3>
                            
                        </div>

                       
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-hover align-middle" id="approvalTable">

                <thead>
                    <tr>
                        <th>Sl No</th>
                        <th>PSU Name</th>
                        <th>Submitted On</th>
                        <th>Status</th>
                        <th>View</th>
                    </tr>
                </thead>

                <tbody>

                    <% approved.forEach((item, i) => { %>
                    
                    <tr>
                        <td>
                            <strong><%= i+ 1 %></strong>
                        </td>
                        <td>
                            <strong><%= item.Psu_Name %></strong>
                        </td>

                        <td>
                            <% 
                                const d = new Date(item.created_at);
                                let formattedDate = '';
                                if (!isNaN(d.getTime())) {
                                    const dd = String(d.getDate()).padStart(2, '0');
                                    const mm = String(d.getMonth() + 1).padStart(2, '0');
                                    const yy = String(d.getFullYear()).slice(-2);
                                    formattedDate = `${dd}-${mm}-20${yy}`;
                                } else {
                                    formattedDate = item.created_at || '';
                                }
                            %>
                            <%= formattedDate %>
                        </td>

                        <td>
                       <% 
  const statusLabels = {
    4: 'Pending at Secretary',
    5: 'Rejected by Secretary',
    6: 'Pending at Finance',
    7: 'Rejected by Finance',
    8: 'Approved'
  };
  const label = statusLabels[item.status] || 'Unknown';
  const badgeClass = item.status === 8 ? 'bg-success' : (item.status % 2 === 0 ? 'bg-info' : 'bg-danger');
%>
<span class="badge <%= badgeClass %>"><%= label %></span>
                        </td>

                       <td>
    <button
        type="button"
        class="btn btn-info btn-sm"
        data-bs-toggle="modal"
        data-bs-target="#profileModal"

        data-authorized="<%= item.Auth_Share_Capital %>"
        data-subscribed="<%= item.Auth_Share_Capital %>"
        data-paidup="<%= item.Paid_Share_Capital %>"
        data-govtamount="<%= item.Govt_Contri_Amt %>"
        data-govtpercent="<%= item.Govt_Contri_Percent %>"
        data-shareholder="<%= item.NameOf_Share_Holder %>"
        data-roc="<%= item.roc_document %>"

        onclick="showProfile(this)"
    >
        View
    </button>
</td>

                       

                    </tr>

                    <% }) %>

                </tbody>

            </table>


            <div class="modal fade" id="profileModal" tabindex="-1">
    <div class="modal-dialog modal-lg ">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">PSU Profile Details</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <table class="table table-bordered">

                    <tr>
                        <th>Authorized Share Capital</th>
                        <td id="authorized"></td>
                    </tr>

                    <tr>
                        <th>Subscribed Share Capital</th>
                        <td id="subscribed"></td>
                    </tr>

                    <tr>
                        <th>Paid-up Share Capital</th>
                        <td id="paidup"></td>
                    </tr>

                    <tr>
                        <th>Govt. Contribution Amount</th>
                        <td id="govtamount"></td>
                    </tr>

                    <tr>
                        <th>Govt. Contribution Percent</th>
                        <td id="govtpercent"></td>
                    </tr>

                    <tr>
                        <th>Share Holders</th>
                        <td id="shareholder"></td>
                    </tr>

                    <tr>
                        <th>ROC Document</th>
                        <td id="roc"></td>
                    </tr>

                </table>

            </div>

        </div>
    </div>
</div>

<script>
function showProfile(btn) {
    const values = {
        authorized: btn.dataset.authorized || 'N/A',
        subscribed: btn.dataset.subscribed || 'N/A',
        paidup: btn.dataset.paidup || 'N/A',
        govtamount: btn.dataset.govtamount || 'N/A',
        govtpercent: btn.dataset.govtpercent || 'N/A',
        shareholder: btn.dataset.shareholder || 'N/A'
    };

    Object.entries(values).forEach(([key, value]) => {
        const element = document.getElementById(key);
        if (element) {
            element.textContent = value;
        }
    });

    const roc = btn.dataset.roc || '';
    const rocElement = document.getElementById('roc');
    if (rocElement) {
        let href = roc.trim();
        if (href.startsWith('public/')) {
            href = href.replace(/^public\//, '');
        }
        if (href && !href.startsWith('/')) {
            href = '/' + href;
        }
        rocElement.innerHTML = href
            ? `<a href="${href}" target="_blank">View Document</a>`
            : 'N/A';
    }
}
</script>

        </div>
    </div>

</div>

