<div class="">
  <h3>PSU Profile Data</h3>
  <hr>
  <div class="row">
    <div class="col-md-3">
      <label for="SelectDmdNo">Select Demand</label>
      <select id="SelectDmdNo" class="form-control mb-3">
        <option value="">-- Select Demand --</option>
        <% DemantData.forEach(function(demand) { %>
          <option value="<%= demand.DmdNo %>">
            <%= demand.DmdNo %> - <%= demand.DeptName %>
          </option>
          <% }); %>
      </select>
    </div>
    <div class="col-md-3">
      <label for="SelectDmdNo">Select PSU</label>
      <select id="SelectPsu" class="form-control mb-3">

        <div id="psuList"></div>
      </select>
    </div>
    <div class="col-md-3">
      <label for="SelectFinYear">Financial Year</label>
      <select id="SelectFinYear" class="form-control mb-3" >
        <option value="">-- Select Financial Year --</option>
        <option value="2020-21">2020-21</option>
        <option value="2021-22">2021-22</option>
        <option value="2022-23">2022-23</option>
        <option value="2023-24">2023-24</option>
        <option value="2024-25">2024-25</option>
      </select>
    </div>
    <div class="col-md-3 d-flex align-items-end">
      <button class="btn btn-primary w-80 mb-3" id="getProfileData">View</button>
      <button class="btn btn-warning w-80 mb-3" id="addProfileData">Add</button>
    </div>
  </div>

  <div class="modal fade" id="profileDataModal" tabindex="-1" role="dialog" aria-labelledby="previewModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="previewModalLabel">Add PSU Profile Data</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <!-- Preview content will be injected here by JavaScript -->
          <div id="previewContent">
            <div class="card mt-4">

              <div class="card-body">
                <form class="forms-sample" id="profileDataForm">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <div class="form-group row">
                    <label for="txtAuthorizedShareCap" class="col-sm-3 col-form-label">Authorized Share Capital</label>
                    <div class="col-sm-9">
                      <input type="text" class="form-control" id="txtAuthorizedShareCap" name="txtAuthorizedShareCap"
                        placeholder="Authorized Share Capital" value="">
                    </div>
                  </div>

                  <div class="form-group row">
                    <label for="txtSubscribedShareCap" class="col-sm-3 col-form-label">Subscribed Share Capital</label>
                    <div class="col-sm-9">
                      <input type="text" class="form-control" id="txtSubscribedShareCap" name="txtSubscribedShareCap"
                        placeholder="Subscribed Share Capital" value="">
                    </div>
                  </div>

                  <div class="form-group row">
                    <label for="txtPaidupShareCap" class="col-sm-3 col-form-label">Paid-up Share Capital</label>
                    <div class="col-sm-9">
                      <input type="text" class="form-control" id="txtPaidupShareCap" name="txtPaidupShareCap"
                        placeholder="Paid-up Share Capital" value="">
                    </div>
                  </div>

                  <button type="submit" class="btn btn-primary">Submit</button>
                </form>
              </div>
            </div>
          </div>
          <div class="modal-footer">

          </div>
        </div>
      </div>
    </div>
</div>
    <div id="profileDataDiv"></div>

    <!-- <div class="mt-3 d-none" id="downloadBtns">
      <button id="downloadExcel" class="btn btn-success">Download Excel</button>
      <button id="downloadPdf" class="btn btn-danger">Download PDF</button>
    </div> -->
  </div>