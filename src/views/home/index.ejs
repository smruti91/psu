                 <!-- Login Form Section -->
                <div class="col-lg-5 col-md-6">
                    <div class="login-form-container">
                        <h3><i class="fas fa-lock me-2"></i>Secure Login</h3>
                        
                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger">
                            <ul>
                                <% errors.forEach(e => { %>
                                <li><%= e.msg %></li>
                                <% }) %>
                            </ul>
                            </div>
                        <% } %>

                        <form action="/auth/login" method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="captchaId" value="<%= captchaId ? captchaId : '' %>">
                            <div class="mb-3">
                                <label for="username" class="form-label"><i class="fas fa-user me-2"></i>Username</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-user"></i>
                                    </span>
                                    <input type="text" class="form-control" name="username" id="username" placeholder="Enter your username" value="<%= old && old.username ? old.username : '' %>" required>
                                </div>
                                <small class="form-text text-muted">Username is case-sensitive</small>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label"><i class="fas fa-key me-2"></i>Password</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input type="password" class="form-control" name="password" id="password" placeholder="Enter your password" required>
                                </div>
                                <small class="form-text text-muted">Password is case-sensitive</small>
                            </div>

                            <!-- CAPTCHA Section -->
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-shield-alt me-2"></i>Security Code (CAPTCHA)</label>
                                <div class="captcha-container" style="border: 1px solid #dee2e6; padding: 10px; border-radius: 4px; background: #f8f9fa; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between;">
                                    <div id="captcha-svg" style="flex: 1; text-align: center;">
                                        <% if (captcha) { %>
                                            <%- captcha %>
                                        <% } else { %>
                                            <svg style="width: 200px; height: 80px; background: #fff;"><text>Loading...</text></svg>
                                        <% } %>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary ms-2" id="refresh-captcha" style="white-space: nowrap; padding: 8px 12px;">
                                        <i class="fas fa-sync-alt"></i> Refresh
                                    </button>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-key"></i>
                                    </span>
                                    <input type="text" class="form-control" name="captcha" id="captcha" placeholder="Enter security code" required>
                                </div>
                                <small class="form-text text-muted">CAPTCHA is case-sensitive. Enter exactly as shown.</small>
                            </div>
                            
                            <button type="submit" class="btn btn-primary btn-login w-100">
                                <i class="fas fa-sign-in-alt me-2"></i>Login to System
                            </button>
                            <p class="mt-3"><i class="fas fa-info-circle me-2"></i>Don't have an account? <a href="#" class="text-primary" id="register-link">Register here</a></p>
                            <div class="text-center mt-3">
                                <a href="#" class="text-muted">
                                    <i class="fas fa-question-circle me-1"></i>Forgot Password?
                                </a>
                            </div>
                        </form>
                    </div>

                    <!-- register form -->
                </div>
                
                </div>

               
            </div>
        </div>