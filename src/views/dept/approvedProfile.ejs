<div class="container-fluid py-4">

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h3 class="mb-1">Approved PSU Profile </h3>
                            
                        </div>

                       
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-hover align-middle" id="approvalTable">

                <thead>
                    <tr>
                        <th>Sl No</th>
                        <th>PSU Name</th>
                        <th>Submitted On</th>
                        <th>Status</th>
                        
                    </tr>
                </thead>

                <tbody>

                    <% approved.forEach((item, i) => { %>

                    <tr>
                        <td>
                            <strong><%= i+ 1 %></strong>
                        </td>
                        <td>
                            <strong><%= item.Psu_Name %></strong>
                        </td>

                        <td>
                            <% 
                                const d = new Date(item.created_at);
                                let formattedDate = '';
                                if (!isNaN(d.getTime())) {
                                    const dd = String(d.getDate()).padStart(2, '0');
                                    const mm = String(d.getMonth() + 1).padStart(2, '0');
                                    const yy = String(d.getFullYear()).slice(-2);
                                    formattedDate = `${dd}-${mm}-20${yy}`;
                                } else {
                                    formattedDate = item.created_at || '';
                                }
                            %>
                            <%= formattedDate %>
                        </td>

                        <td>
                       <% 
  const statusLabels = {
    4: 'Pending at Secretary',
    5: 'Rejected by Secretary',
    6: 'Pending at Finance',
    7: 'Rejected by Finance',
    8: 'Approved'
  };
  const label = statusLabels[item.status] || 'Unknown';
  const badgeClass = item.status === 8 ? 'bg-success' : (item.status % 2 === 0 ? 'bg-info' : 'bg-danger');
%>
<span class="badge <%= badgeClass %>"><%= label %></span>
                        </td>

                       

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>
    </div>

</div>

