<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Automation of PSUs DATA - Government of Odisha</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --odisha-blue: #1e3a8a;
            --odisha-saffron: #ff6b35;
            --odisha-green: #059669;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }
        
        .navbar {
            background: linear-gradient(135deg, var(--odisha-blue) 0%, #1e40af 100%);
            box-shadow: 0 2px 20px rgba(30, 58, 138, 0.2);
            padding: 1rem 0;
        }
        
        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
        }
        
        .logo-container {
            width: 80px;
            height: 80px;
            /* background: white; */
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        .logo-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        
        .hero-section {
            min-height: 80vh;
            display: flex;
            align-items: center;
            padding: 4rem 0;
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        }
        
        .carousel-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            margin: 1rem 0;
            position: relative;
            height: 450px;
        }
        
        /* Pure CSS Carousel */
        .css-carousel {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        
        .css-carousel input[type="radio"] {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }
        
        .carousel-slides {
            position: relative;
            width: 500%;
            height: 100%;
            display: flex;
            transition: transform 0.6s ease-in-out;
        }
        
        .carousel-slide {
            width: 20%;
            height: 100%;
            position: relative;
        }
        
        .demo-placeholder {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            font-size: 1.2rem;
            font-weight: 600;
            color: white;
            text-align: center;
            padding: 2rem;
        }
        
        .demo-placeholder i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.8;
        }
        
        .demo-bg-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .demo-bg-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
        .demo-bg-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
        .demo-bg-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
        .demo-bg-5 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
        
        .carousel-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.7));
            padding: 2rem;
            color: white;
        }
        
        /* Carousel Navigation */
        .carousel-indicators {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 10px;
            z-index: 10;
        }
        
        .carousel-indicators label {
            width: 15px;
            height: 15px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid white;
        }
        
        .carousel-indicators label:hover {
            background: rgba(255, 255, 255, 0.8);
            transform: scale(1.1);
        }
        
        /* Navigation Buttons - Simplified Approach */
        .carousel-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(30, 58, 138, 0.8);
            color: white;
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            z-index: 15;
            opacity: 0.7;
        }
        
        .carousel-nav:hover {
            background: var(--odisha-blue);
            opacity: 1;
            transform: translateY(-50%) scale(1.1);
            box-shadow: 0 5px 15px rgba(30, 58, 138, 0.4);
        }
        
        .carousel-nav-prev {
            left: 15px;
        }
        
        .carousel-nav-next {
            right: 15px;
        }
        
        /* Show navigation buttons based on current slide */
        #slide1:checked ~ .nav-buttons .nav-prev-5,
        #slide1:checked ~ .nav-buttons .nav-next-2,
        #slide2:checked ~ .nav-buttons .nav-prev-1,
        #slide2:checked ~ .nav-buttons .nav-next-3,
        #slide3:checked ~ .nav-buttons .nav-prev-2,
        #slide3:checked ~ .nav-buttons .nav-next-4,
        #slide4:checked ~ .nav-buttons .nav-prev-3,
        #slide4:checked ~ .nav-buttons .nav-next-5,
        #slide5:checked ~ .nav-buttons .nav-prev-4,
        #slide5:checked ~ .nav-buttons .nav-next-1 {
            display: flex !important;
        }
        
        /* Carousel Controls */
        #slide1:checked ~ .carousel-slides { transform: translateX(0%); }
        #slide2:checked ~ .carousel-slides { transform: translateX(-20%); }
        #slide3:checked ~ .carousel-slides { transform: translateX(-40%); }
        #slide4:checked ~ .carousel-slides { transform: translateX(-60%); }
        #slide5:checked ~ .carousel-slides { transform: translateX(-80%); }
        
        #slide1:checked ~ .carousel-indicators label:nth-child(1),
        #slide2:checked ~ .carousel-indicators label:nth-child(2),
        #slide3:checked ~ .carousel-indicators label:nth-child(3),
        #slide4:checked ~ .carousel-indicators label:nth-child(4),
        #slide5:checked ~ .carousel-indicators label:nth-child(5) {
            background: var(--odisha-saffron);
            transform: scale(1.3);
        }
        
        /* Auto-play animation */
        #slide1:checked ~ .carousel-slides { animation: autoplay1 20s infinite; }
        #slide2:checked ~ .carousel-slides { animation: autoplay2 20s infinite; }
        #slide3:checked ~ .carousel-slides { animation: autoplay3 20s infinite; }
        #slide4:checked ~ .carousel-slides { animation: autoplay4 20s infinite; }
        #slide5:checked ~ .carousel-slides { animation: autoplay5 20s infinite; }
        
        @keyframes autoplay1 {
            0%, 20% { transform: translateX(0%); }
            25%, 45% { transform: translateX(-20%); }
            50%, 70% { transform: translateX(-40%); }
            75%, 95% { transform: translateX(-60%); }
            100% { transform: translateX(-80%); }
        }
        
        @keyframes autoplay2 {
            0%, 20% { transform: translateX(-20%); }
            25%, 45% { transform: translateX(-40%); }
            50%, 70% { transform: translateX(-60%); }
            75%, 95% { transform: translateX(-80%); }
            100% { transform: translateX(0%); }
        }
        
        @keyframes autoplay3 {
            0%, 20% { transform: translateX(-40%); }
            25%, 45% { transform: translateX(-60%); }
            50%, 70% { transform: translateX(-80%); }
            75%, 95% { transform: translateX(0%); }
            100% { transform: translateX(-20%); }
        }
        
        @keyframes autoplay4 {
            0%, 20% { transform: translateX(-60%); }
            25%, 45% { transform: translateX(-80%); }
            50%, 70% { transform: translateX(0%); }
            75%, 95% { transform: translateX(-20%); }
            100% { transform: translateX(-40%); }
        }
        
        @keyframes autoplay5 {
            0%, 20% { transform: translateX(-80%); }
            25%, 45% { transform: translateX(0%); }
            50%, 70% { transform: translateX(-20%); }
            75%, 95% { transform: translateX(-40%); }
            100% { transform: translateX(-60%); }
        }
        
        .demo-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--odisha-saffron);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            z-index: 10;
        }
        
        .login-form-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 25px 50px rgba(30, 58, 138, 0.15);
            padding: 3rem;
            margin: 1rem 0;
            border-top: 4px solid var(--odisha-saffron);
        }
        
        .login-form-container h3 {
            color: var(--odisha-blue);
            font-weight: 700;
            margin-bottom: 2rem;
            text-align: center;
        }
        
        .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 0 10px 10px 0;
            padding: 12px 16px;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus {
            border-color: var(--odisha-blue);
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        
        .input-group-text {
            background: linear-gradient(135deg, var(--odisha-blue) 0%, #1e40af 100%);
            color: white;
            border: 2px solid var(--odisha-blue);
            border-radius: 10px 0 0 10px;
            border-right: none;
            height: 3.3rem;
        }
        
        .input-group .form-control {
            border-left: none;
        }
        
        .input-group:focus-within .input-group-text {
            border-color: var(--odisha-blue);
        }
        
        .input-group:focus-within .form-control {
            border-left: 2px solid var(--odisha-blue);
        }
        
        .btn-login {
            background: linear-gradient(135deg, var(--odisha-blue) 0%, #1e40af 100%);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            width: 100%;
        }
        
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.3);
        }
        
        .footer {
            background: linear-gradient(135deg, var(--odisha-blue) 0%, #1e40af 100%);
            color: white;
            padding: 3rem 0 2rem;
            margin-top: 4rem;
        }
        
        .footer h5 {
            color: var(--odisha-saffron);
            margin-bottom: 1rem;
        }
        
        .footer a {
            color: #cbd5e1;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .footer a:hover {
            color: white;
        }
        
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.2);
            padding-top: 2rem;
            margin-top: 2rem;
            text-align: center;
        }
        
        @media (max-width: 768px) {
            .hero-section {
                min-height: auto;
            }
            
            .carousel-container,
            .login-form-container {
                margin: 1rem 0;
            }
            
            .navbar-brand {
                font-size: 1.2rem;
            }
            
            .logo-container {
                width: 40px;
                height: 40px;
            }
            
            .carousel-container {
                height: 350px;
            }
        }
    </style>
</head>
<body>
