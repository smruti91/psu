<script src="/js/common.js"></script>
<script>
    // CAPTCHA refresh functionality
    document.addEventListener('DOMContentLoaded', function() {
        const refreshBtn = document.getElementById('refresh-captcha');
        
        if (refreshBtn) {
            refreshBtn.addEventListener('click', function(e) {
                e.preventDefault();
                
                fetch('/auth/refresh-captcha', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update CAPTCHA image
                        document.getElementById('captcha-svg').innerHTML = data.captcha;
                        // Clear the input field
                        document.getElementById('captcha').value = '';
                        document.getElementById('captcha').focus();
                    } else {
                        alert('Error refreshing CAPTCHA. Please try again.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error refreshing CAPTCHA. Please try again.');
                });
            });
        }

        // Session timeout warning
        let sessionTimeout = 15 * 60 * 1000; // 15 minutes
        let warningTimeout = 14 * 60 * 1000; // 14 minutes
        
        let sessionWarningShown = false;

        function resetSessionTimeout() {
            sessionWarningShown = false;
            clearTimeout(sessionWarningTimeout);
            clearTimeout(sessionTimeoutHandler);
            
            if (document.querySelector('.session-warning-alert')) {
                document.querySelector('.session-warning-alert').remove();
            }

            // Set new timeout
            sessionWarningTimeout = setTimeout(function() {
                if (!sessionWarningShown) {
                    showSessionWarning();
                    sessionWarningShown = true;
                }
            }, warningTimeout);

            sessionTimeoutHandler = setTimeout(function() {
                alert('Your session has expired due to inactivity. Please login again.');
                window.location.href = '/';
            }, sessionTimeout);
        }

        function showSessionWarning() {
            const warning = document.createElement('div');
            warning.className = 'alert alert-warning session-warning-alert';
            warning.style.position = 'fixed';
            warning.style.top = '20px';
            warning.style.right = '20px';
            warning.style.zIndex = '9999';
            warning.style.maxWidth = '400px';
            warning.innerHTML = `
                <i class="fas fa-clock me-2"></i>
                <strong>Session Timeout Warning!</strong>
                <p>Your session will expire in 1 minute due to inactivity. Click anywhere to continue.</p>
                <button class="btn btn-sm btn-primary" onclick="document.location.reload();">Continue Session</button>
            `;
            document.body.appendChild(warning);
        }

        let sessionWarningTimeout;
        let sessionTimeoutHandler;

        // Reset session timeout on user activity
        document.addEventListener('mousemove', resetSessionTimeout);
        document.addEventListener('keypress', resetSessionTimeout);
        document.addEventListener('click', resetSessionTimeout);
        document.addEventListener('scroll', resetSessionTimeout);

        // Initial setup
        resetSessionTimeout();
    });
</script>

</body>
</html>