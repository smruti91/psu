<style>
    /* Container Styling */
    .container {
        max-width: 600px;
        margin: 2rem auto;
        padding: 0 1rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #333;
    }

    h2 {
        font-size: 1.75rem;
        color: #1a202c;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 0.5rem;
    }
    .text-status {
        font-size: 1rem;
        color: #ff9800; /* Orange color for pending status */
        font-weight: bold;
    }
</style>
<div class="container">
    <h2>Profile Details </h2>

    <% if (psuProfile) { %>

        <div class="card mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">PSU Profile Data</h5>
                     
                        <button type="button" class="btn btn-warning btn-sm" id="editProfileDataBtn">Edit</button>
                        
                       
                   
                </div>
                <p class="card-text">Authorized Share Capital: <span id="authorizedShareCapValue">
                        <%= psuProfile.Auth_Share_Capital %>
                    </span></p>
                <p class="card-text">Subscribed Share Capital: <span id="subscribedShareCapValue">
                        <%=psuProfile.Sub_Share_Capital %>
                    </span></p>
                <p class="card-text">Paid-up Share Capital: <span id="paidupShareCapValue">
                        <%=psuProfile.Paid_Share_Capital %>
                    </span>
                </p>
                <p class="card-text">Govt. Contribution in Amount: <span id="govtContributionAmtValue">
                        <%=psuProfile.Govt_Contri_Amt %>
                    </span>
                </p>
                <p class="card-text">Govt. Contribution in Percent: <span id="govtContributionPercentValue">
                        <%=psuProfile.Govt_Contri_Percent %>
                    </span>
                </p>
                <p class="card-text">ROC Document: <span id="rocDocument">
                                                            
                    <a  href="/<%= psuProfile.roc_document.replace(/^public\//,'') %>" target="_blank" >View</a>
                </p>
                <div class="mt-3">
    <h6>Share Holders</h6>

    <% if (shareholders && shareholders.length > 0) { %>

        <table class="table table-bordered table-sm">
            <thead>
                <tr>
                    <th>Sl. No.</th>
                    <th>Share Holder Name</th>
                    <th>Share %</th>
                </tr>
            </thead>
            <tbody>
                <% shareholders.forEach((shareholder, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= shareholder.shareholder_name %></td>
                        <td><%= shareholder.shareholder_percent %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    <% } else { %>

        <p>N/A</p>

    <% } %>
</div>
                
                <p class="card-text"> <span id="">
                    <% if(psuProfile.status == 0){ %>
                    <button
                        class="btn btn-success"
                        id="sendApprovalBtn"
                        data-id="<%= psuProfile.id %>">
                        Send For Approval
                    </button>
                  <% }else if(psuProfile.status == 6) { %>
                        <p class="text-status">Pending At Finanace</p>
                      <% } %>  
                      
                </p>
                <button
                            class="btn  btn-primary btn-sm historyBtn"
                            data-id="<%= psuProfile.id %>"
                            data-toggle="modal"
                            data-target="#historyModal">

                            <i class="fa fa-history"></i>
                            History

                        </button>
            </div>
        </div>
        <% } else { %>

            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">No Profile Data Available</h5>
                    <p class="card-text">There is currently no profile data for this PSU. Please add the profile data to
                        view it here.</p>
                    <button class="btn btn-success w-80 mb-3" id="addProfileData">Add</button>
                   
                </div>
            </div>
            <% } %>
                <div class="modal fade" id="profileDataModal" tabindex="-1" role="dialog"
                    aria-labelledby="previewModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-md" role="document">
                        <div class="modal-content" style="width:160%">
                            <div class="modal-header">
                                <h5 class="modal-title" id="previewModalLabel">Add PSU Profile Data</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                               
                                <!-- Preview content will be injected here by JavaScript -->
                                <div id="previewContent">
                                    <div class="card mt-4">

                                        <div class="card-body">
                                            <form class="forms-sample" id="profileDataForm">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                                <div class="form-group row">
                                                    <label for="txtAuthorizedShareCap"
                                                        class="col-sm-3 col-form-label">Authorized Share Capital</label>
                                                    <div class="col-sm-9">
                                                        <input type="text" class="form-control"
                                                            id="txtAuthorizedShareCap" name="Auth_Share_Capital"
                                                            placeholder="Authorized Share Capital" value="<%= psuProfile && psuProfile.Auth_Share_Capital ? psuProfile.Auth_Share_Capital : '' %>">
                                                    </div>
                                                </div>

                                                <div class="form-group row">
                                                    <label for="txtSubscribedShareCap"
                                                        class="col-sm-3 col-form-label">Subscribed Share Capital</label>
                                                    <div class="col-sm-9">
                                                        <input type="text" class="form-control"
                                                            id="txtSubscribedShareCap" name="Sub_Share_Capital"
                                                            placeholder="Subscribed Share Capital" value="<%= psuProfile && psuProfile.Sub_Share_Capital ? psuProfile.Sub_Share_Capital : '' %>">
                                                    </div>
                                                </div>

                                                <div class="form-group row">
                                                    <label for="txtPaidupShareCap"
                                                        class="col-sm-3 col-form-label">Paid-up Share Capital</label>
                                                    <div class="col-sm-9">
                                                        <input type="text" class="form-control" id="txtPaidupShareCap"
                                                            name="Paid_Share_Capital" placeholder="Paid-up Share Capital"
                                                            value="">
                                                    </div>
                                                </div>
                                                <div class="form-group row">
                                                        <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Govt.
                                                            Contribution in Amount</label>
                                                        <div class="col-sm-9">
                                                            <input type="text" class="form-control" id="txtGovtContribution"
                                                                name="Govt_Contri_Amt" placeholder="Govt. Contribution"
                                                                value="<%= psuProfile && psuProfile.Govt_Contri_Amt ? psuProfile.Govt_Contri_Amt : '' %>">
                                                            <div class="invalid-feedback" id="error_txtGovtContribution"></div>
                                                        </div>
                                                    </div>
                                                    <div class="form-group row">
                                                        <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Govt.
                                                            Contribution in Percent</label>
                                                        <div class="col-sm-9">
                                                            <input type="text" class="form-control" id="txtGovtContributionPercent"
                                                                name="Govt_Contri_Percent" placeholder="Govt. Contribution In Percent"
                                                                value="<%= psuProfile && psuProfile.Govt_Contri_Percent ? psuProfile.Govt_Contri_Percent : '' %>" readonly>
                                                            <div class="invalid-feedback" id="error_txtGovtContributionPercent"></div>
                                                        </div>
                                                    </div>
                                                    <div class="form-group row">
                                                        <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Name of the Share Holders</label>
                                                        <div class="col-sm-9">
                                                            <div id="shareholdersContainer">
                                                            <div class="shareholder-input-row row align-items-center mb-2">
                                                                <div class="col-md-2">
                                                                    <input type="text" class="form-control shareholder-slno text-dark" value="1" readonly>
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <input type="text" class="form-control" name="shareholders[]"
                                                                        placeholder="Name of the Share Holder">
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <input type="number" class="form-control"
                                                                        name="shareholder_percent[]"
                                                                        placeholder="Share %"
                                                                        min="0" max="100" step="0.01">
                                                                </div>
                                                                <div class="col-md-1">
                                                                    <button type="button" class="btn btn-danger btn-sm remove-shareholder-btn">
                                                                        ✕
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <button type="button" class="btn btn-success btn-sm mt-2" id="addShareholderBtn">
                                                            + Add Shareholder
                                                        </button>
                                                            <div class="invalid-feedback" id="error_shareholders"></div>
                                                        </div>
                                                    </div>
                                                 
                                                    <div class="form-group row">
                                                        <label for="roc_document" class="col-sm-3 col-form-label">
                                                            Additional Roc Document
                                                        </label>
                                                        <div class="col-sm-9">
                                                            <% if (psuProfile && psuProfile.roc_document) { %>
                                                                <div class="d-flex align-items-center mb-2" id="rocDocumentActions">
                                                                    <a href="/<%= psuProfile.roc_document.replace(/^public\//,'') %>" target="_blank" class="mr-2">View existing ROC document</a>
                                                                    <button type="button" class="btn btn-danger btn-sm" id="deleteRocDocumentBtn">Delete</button>
                                                                </div>
                                                            <% } %>
                                                            <div id="rocUploadContainer" style="<%= psuProfile && psuProfile.roc_document ? 'display:none;' : '' %>">
                                                                <input type="file" class="form-control" id="roc_document" 
                                                                    name="roc_document" accept=".pdf">
                                                                <small class="form-text text-muted">Upload a new PDF to replace the existing document.</small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" name="psu_id" value="<%= psuId %>" >
                                                    <input type="hidden" name="dmd_no" value="<%= dmdNo %>" >
                                                    <input type="hidden" id="profileId" name="profile_id" value="<%= psuProfile && psuProfile.id ? psuProfile.id : '' %>" >
                                                <button type="submit" class="btn btn-primary" id="profileSubmitBtn">Submit</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
</div>