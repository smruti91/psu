<!-- Stepper UI (hidden by default) -->
 <h4 class="text-center text-info" >Add Data For Year Of <%= Fin_Yr %> </h4>
<% if (!profileData) { %>
    <div class="alert alert-warning text-center" role="alert">
        Your profile is incomplete. Please complete your profile before adding year-wise data.
    </div>
    
<% } %>
  
<div id="stepperContainer">
    <div class="container mt-4" style="background: #325c87;
    color: #fff;
    padding-top: 10px;
    border-radius: 20px;"
    
    >
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="stepper d-flex justify-content-between mb-4">
                    <div class="step" id="step-indicator-1">
                        <div class="circle">1</div>
                        <div class="label">Year Wise Data</div>
                    </div>
                    <div class="step" id="step-indicator-2">
                        <div class="circle">2</div>
                        <div class="label">Income Statement</div>
                    </div>
                    <div class="step" id="step-indicator-3">
                        <div class="circle">3</div>
                        <div class="label">Balance Sheet</div>
                    </div>
                    <div class="step" id="step-indicator-4">
                        <div class="circle">4</div>
                        <div class="label">Profit & Loss</div>
                    </div>
                    <div class="step" id="step-indicator-5">
                        <div class="circle">5</div>
                        <div class="label">Govt. Relationship</div>
                    </div>
                    <div class="step" id="step-indicator-6">
                        <div class="circle">6</div>
                        <div class="label">Annual Report</div>
                    </div>
                </div>
                
                <div id="step-content-1" class="step-content">
                    <form class="forms-sample" id="psuFormYearWiseData" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div id="psuFormYearWiseDataErrors" class="alert alert-danger" style="display:none;"></div>
                        <div id="psuFormYearWiseDataSuccess" class="alert alert-success" style="display:none;"></div>

                        <div class="form-group row">
                            <label for="exampleInputUsername2" class="col-sm-3 col-form-label">Name Of the
                                PSU</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtNameofPSU" name="txtNameofPSU"
                                    placeholder="Name of the PSU"
                                    value="<%= typeof Psu_Name !== 'undefined' ? Psu_Name : (typeof user !== 'undefined' && user.Psu_Name ? user.Psu_Name : '') %>"
                                    readonly>
                                <div class="invalid-feedback" id="error_txtNameofPSU"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputEmail2" class="col-sm-3 col-form-label">Authorized Share
                                Capital</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtAuthorizedShareCap"
                                    name="txtAuthorizedShareCap" placeholder="Authorized Share Capital"
                                    value="<%= profileData ? profileData.Auth_Share_Capital : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtAuthorizedShareCap"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputMobile" class="col-sm-3 col-form-label">Subscribed Share
                                Capital</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtSubShareCap" name="txtSubShareCap"
                                    placeholder="Subscribed Share Capital"
                                    value="<%= profileData ? profileData.Sub_Share_Capital : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtSubShareCap"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputPassword2" class="col-sm-3 col-form-label">Paid-up Share
                                Capital</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtPaidUpShareCap" name="txtPaidUpShareCap"
                                    placeholder="Paid-up Share Capital"
                                    value="<%= profileData ? profileData.Paid_Share_Capital : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtPaidUpShareCap"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Govt.
                                Contribution in Amount</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtGovtContribution"
                                    name="txtGovtContribution" placeholder="Govt. Contribution"
                                    value="<%= profileData ? profileData.Govt_Contri_Amt : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtGovtContribution"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Govt.
                                Contribution in Percent</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtGovtContributionPercent"
                                    name="txtGovtContributionPercent" placeholder="Govt. Contribution In Percent"
                                    value="<%= profileData ? profileData.Govt_Contri_Percent : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtGovtContributionPercent"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Name of the
                                Share Holders</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtNameofShareHolders"
                                    name="txtNameofShareHolders" placeholder="Name of the Share Holders"
                                    value="<%= profileData ? profileData.NameOf_Share_Holder : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtNameofShareHolders"></div>
                            </div>
                        </div>
                     
                        <div class="d-flex justify-content-end mt-4 py-5">
                            <input type="hidden" name="txtFinYr" id="txtFinYr"
                                value="<%= typeof Fin_Yr !== 'undefined' ? Fin_Yr : '' %>">
                             <input type="hidden" name="profile_id" id="profile_id"
                                value="<%= profileData.id %>">
                            <% if (yearWiseData) { %>
                                <% if (yearWiseData.status === 0) { %>
                                <input type="hidden" name="yearWiseId" id="yearWiseId" value="<%= yearWiseData.id %>">
                                <button type="submit" class="btn btn-warning mr-2 btn-update-step1" data-step="1">Update</button>
                                <% }%>
                                <% } else { %>
                                    <button type="submit" class="btn btn-info mr-2 btn-save-step1" data-step="1">Save</button>
                                    <% } %>
                                        <button type="button" class="btn btn-primary" id="nextStep1">Next</button>
                        </div>
                        <!-- Edit button container - shown after form submit -->
                        <div id="editButtonContainerStep1" class="mt-3" style="display:none;">
                            <button type="button" class="btn btn-warning" id="btnEditStep1">Edit</button>
                        </div>
                    </form>

                </div>
                <div id="step-content-2" class="step-content" style="display:none;">
                     <!-- Step 2: Income Statement Indicator -->
                    <form class="forms-sample" id="psuFormIncomeStatement">
                        <div id="psuFormIncomeStatementErrors" class="alert alert-danger" style="display:none;"></div>
                        <div id="psuFormIncomeStatementSuccess" class="alert alert-success" style="display:none;"></div>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total Revenue</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotRevenue" name="tot_revenue"
                                    placeholder="Total Revenue"
                                    value="<%= incomeSheetData ? incomeSheetData.tot_revenue || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Cost of Goods Sold</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtCostofGoodsSold" name="cost_ofgoods_sold"
                                    placeholder="Cost of Goods Sold"
                                    value="<%= incomeSheetData ? incomeSheetData.cost_ofgoods_sold || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Operating expenses</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtOprexpenses" name="operating_expenses"
                                    placeholder="Operating Expenses"
                                    value="<%= incomeSheetData ? incomeSheetData.operating_expenses || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total expenses</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotalExpenses" name="tot_expenses"
                                    placeholder="Total Expenses"
                                    value="<%= incomeSheetData ? incomeSheetData.tot_expenses || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">EBITDA</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtEbitda" name="ebitda"
                                    placeholder="EBITDA"
                                    value="<%= incomeSheetData ? incomeSheetData.ebitda || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Depreciation & amortization</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtDepAmor" name="depreciation"
                                    placeholder="Depreciation & amortization"
                                    value="<%= incomeSheetData ? incomeSheetData.depreciation || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">EBIT (Operating profit)</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtEbit" name="ebit_operating"
                                    placeholder="EBIT (Operating profit)"
                                    value="<%= incomeSheetData ? incomeSheetData.ebit_operating || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Interest Expenses</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtIntExpenses" name="int_expenses"
                                    placeholder="Interest Expenses"
                                    value="<%= incomeSheetData ? incomeSheetData.int_expenses || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Tax Expenses</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTaxExpenses" name="tax_expenses"
                                    placeholder="Tax Expenses"
                                    value="<%= incomeSheetData ? incomeSheetData.tax_expenses || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Any Other Expenses</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtAnyExpenses" name="any_other_expenses"
                                    placeholder="Any Other Expenses"
                                    value="<%= incomeSheetData ? incomeSheetData.any_other_expenses || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Net Income</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtNetIncome" name="net_income"
                                    placeholder="Net Income"
                                    value="<%= incomeSheetData ? incomeSheetData.net_income || '' : '' %>">
                            </div>
                        </div>
                        <input type="hidden" name="psu_mstr_id" id="psu_mstr_id"
                            value="<%= yearWiseData ? yearWiseData.id : '' %>">
                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-secondary" id="prevStep2">Previous</button>
                             <div>
                            <% if (incomeSheetData) { %>
                                <% if (yearWiseData.status === 0) { %>
                                    <input type="hidden" name="incomeSheetId" id="incomeSheetId"
                                        value="<%= incomeSheetData.id %>">
                                    <button type="submit" class="btn btn-warning" id="updateStep2">Update</button>
                                <% }%>

                                <% } else { %>
                                    <button type="submit" class="btn btn-info" id="submitStep2">Save</button>
                                    <% } %>
                                     <button type="button" class="btn btn-primary" id="nextStep2">Next</button>
                            </div>
                            <!-- Edit button container - shown after form submit -->
                            <div id="editButtonContainerStep3" class="mt-3" style="display:none;">
                                <button type="button" class="btn btn-warning" id="btnEditStep2">Edit</button>
                            </div>
                        </div>
                    </form>
                </div>
                <div id="step-content-3" class="step-content" style="display:none;">
                    <!-- Step 3: Balance Sheet Indicator -->
                     <form class="forms-sample" id="psuFormBalanceSheet">
                        <div id="psuFormBalanceSheetErrors" class="alert alert-danger" style="display:none;"></div>
                        <div id="psuFormBalanceSheetSuccess" class="alert alert-success" style="display:none;"></div>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total Assets</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotalAssets" name="tot_asset"
                                    placeholder="Total Assets"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_asset || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total Current Assets</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtCurrentAssets" name="tot_curr_asset"
                                    placeholder="Total Current Assets"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_curr_asset || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total Liabilities</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotLiabilities" name="tot_liabilities"
                                    placeholder="Total Liabilities"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_liabilities || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total Current Liabilities</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotCurrLiabilities"
                                    name="tot_curr_liabilities" placeholder="Total Current Liabilities"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_curr_liabilities || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total long-term debt</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotalLongTermDebt"
                                    name="tot_longterm_debt" placeholder="Total long-term debt"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_longterm_debt || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Total equity</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtTotalequity" name="tot_equity"
                                    placeholder="Total equity"
                                    value="<%= balanceSheetData ? balanceSheetData.tot_equity || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Inventory</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtInvetory" name="inventory"
                                    placeholder="Inventory"
                                    value="<%= balanceSheetData ? balanceSheetData.inventory || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Accounts receivable</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtAccountsReceivable" name="acc_receivable"
                                    placeholder="Accounts receivable"
                                    value="<%= balanceSheetData ? balanceSheetData.acc_receivable || '' : '' %>">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Accounts Payable</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtAccountsPayable" name="acc_payble"
                                    placeholder="Accounts Payable"
                                    value="<%= balanceSheetData ? balanceSheetData.acc_payble || '' : '' %>">
                            </div>
                        </div>
                        <input type="hidden" name="psu_mstr_id" id="psu_mstr_id"
                            value="<%= yearWiseData ? yearWiseData.id : '' %>">
                        <div class="d-flex justify-content-between mt-4 py-4">
                            <button type="button" class="btn btn-secondary" id="prevStep3">Previous</button>

                        <div>
                            <% if (balanceSheetData) { %>
                                <% if (yearWiseData.status === 0) { %>
                               <input type="hidden" name="balanceSheetId" id="balanceSheetId"
                                    value="<%= balanceSheetData.id %>">
                                <button type="submit" class="btn btn-warning" id="updateStep3">Update</button>
                                <% }%>

                                <% } else { %>
                                    <button type="submit" class="btn btn-info" id="submitStep3">Save</button>
                                    <% } %>
                                    <button type="button" class="btn btn-primary" id="nextStep3">Next</button>
                        </div>
                        </div>
                        <!-- Edit button container - shown after form submit -->
                        <div id="editButtonContainerStep2" class="mt-3" style="display:none;">
                            <button type="button" class="btn btn-warning" id="btnEditStep3">Edit</button>
                        </div>
                    </form>
                </div>
                <div id="step-content-4" class="step-content" style="display:none;">
                    <!-- Step 4: Profit and Loss -->
                     <form class="forms-sample" id="psuFormProfitLoss" method="POST" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div id="psuFormProfitLossErrors" class="alert alert-danger" style="display:none;"></div>
                        <div id="psuFormProfitLossSuccess" class="alert alert-success" style="display:none;"></div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label">Profit &
                                Loss</label>
                            <div class="col-sm-9">
                                <!-- Radio buttons for Profit/Loss selection -->
                                <div class="mb-2 row">
                                    <div class="form-check form-check-inline d-flex align-items-center">
                                        <input class="form-check-input" type="radio" name="profitLossType" id="profitType" value="profit"
                                            <%= (!profitLossData || profitLossData.profit_loss_type === 'profit' ) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="profitType">Profit</label>
                                    </div>
                                    <div class="form-check form-check-inline d-flex align-items-center">
                                        <input class="form-check-input" type="radio" name="profitLossType" id="lossType" value="loss"
                                            <%= (profitLossData && profitLossData.profit_loss_type === 'loss') ? 'checked' : '' %>>
                                        <label class="form-check-label" for="lossType">Loss</label>
                                    </div>
                                </div>
                                <input type="text" class="form-control" id="txtProfitLossAmount" name="txtProfitLossAmount"
                                    placeholder="Enter Amount"
                                    value="<%= profitLossData && profitLossData.Profit_Loss ? profitLossData.Profit_Loss : '' %>">
                                <div class="invalid-feedback" id="error_txtProfitLossAmount"></div>
                               
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Profit After
                                Tax (PAT)</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtPAT" name="txtPAT"
                                    placeholder="Profit After Tax (PAT)"
                                    value="<%= profitLossData ? profitLossData.PAT : '' %>">
                                <div class="invalid-feedback" id="error_txtPAT"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Dividend
                                Payable</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtDividendPayable"
                                    name="txtDividendPayable" placeholder="Dividend Payable"
                                    value="<%= profitLossData ? profitLossData.Dividend_Payable : '' %>" readonly>
                                <div class="invalid-feedback" id="error_txtDividendPayable"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="exampleInputConfirmPassword2" class="col-sm-3 col-form-label">Dividend
                                Paid</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtDividendpaid" name="txtDividendpaid"
                                    value="<%= profitLossData ? profitLossData.Dividend_Paid : '' %>"
                                    placeholder="Dividend Paid">
                                <div class="invalid-feedback" id="error_txtDividendpaid"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label for="challanReceipt" class="col-sm-3 col-form-label">
                                Challan Receipt
                            </label>

                            <div class="col-sm-9">

                                <% if (profitLossData && profitLossData.chaln_recipt) { %>

                                    <!-- Show existing files -->
                                    <div class="mt-2" id="existingFiles">
                                        <%
                                        var files = profitLossData.chaln_recipt.split(',');
                                        files.forEach(function(file, index) {
                                            if(file && file.trim()) {
                                        %>
                                            <div class="d-flex align-items-center mb-2 existing-file-item">
                                                <a href="/<%= file.trim().replace(/^public\//,'') %>"
                                                target="_blank"
                                                class="btn btn-sm btn-info mr-2">
                                                View File <%= index + 1 %>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-danger delete-file-btn"
                                                        data-id="<%= yearWiseData.id %>"
                                                        data-file-index="<%= index %>">
                                                    Delete
                                                </button>
                                            </div>
                                        <%
                                            }
                                        });
                                        %>
                                    </div>

                                <% } %>

                                <!-- Container for new file uploads -->
                                <div id="challanFilesContainer">
                                    <div class="file-input-row d-flex align-items-center mb-2">
                                        <input type="file"
                                            class="form-control"
                                            name="chaln_recipt"
                                            accept=".pdf">
                                        <button type="button" class="btn btn-danger btn-sm ml-2 remove-file-btn" title="Remove">✕</button>
                                    </div>
                                </div>

                                <!-- Add More Button -->
                                <button type="button" class="btn btn-success btn-sm mt-2" id="addChallanFileBtn">
                                    + Add More
                                </button>

                                <small class="form-text text-muted d-block">
                                    Accepted format: PDF (Max size: 5MB each)
                                </small>

                                <div class="invalid-feedback" id="error_chaln_recipt"></div>

                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 py-5">
                            
                            <input type="hidden" name="yearWiseId" id="yearWiseId"  value="<%= yearWiseData ? yearWiseData.id : '' %>">
                                 <button type="button" class="btn btn-secondary" id="prevStep4">Previous</button>
                            <% if (profitLossData) { %>
                                <% if (yearWiseData.status === 0) { %>
                                
                                <button type="submit" class="btn btn-warning mr-2 btn-update-step4" data-step="1">Update</button>
                                <% }%>
                                <% } else { %>
                                    <button type="submit" class="btn btn-info mr-2 btn-save-step4" data-step="1">Save</button>
                                    <% } %>
                                        <button type="button" class="btn btn-primary" id="nextStep4">Next</button>
                        </div>
                        <!-- Edit button container - shown after form submit -->
                        <div id="editButtonContainerStep1" class="mt-3" style="display:none;">
                            <button type="button" class="btn btn-warning" id="btnEditStep4">Edit</button>
                        </div>
                    </form>
                </div>

                <div id="step-content-5" class="step-content" style="display:none;">
                    <!-- Step 5: Govt. Relationship -->
