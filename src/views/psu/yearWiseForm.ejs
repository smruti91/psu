    <style>
        .stepper {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .step {
            text-align: center;
            flex: 1;
            position: relative;
        }

        .step .circle {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #dee2e6;
            color: #495057;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px auto;
            font-weight: bold;
            font-size: 1.2rem;
            transition: background 0.3s, color 0.3s;
        }

        .step.completed .circle {
            background: #28a745;
            color: #fff;
        }

        .step.active .circle {
            background: #007bff;
            color: #fff;
        }

        .step .label {
            font-size: 0.95rem;
        }

        .step:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 18px;
            right: -58%;
            width: 100%;
            height: 4px;
            background: #dee2e6;
            z-index: 0;
        }

        .step.completed:not(:last-child)::after {
            background: #28a745;
        }
    </style>
    <script>
        // CSRF token helper (used by common.js)
        function getCsrfToken() {
            return document.querySelector('input[name="_csrf"]')?.value || '';
        }
        window.getCsrfToken = getCsrfToken;
    </script>